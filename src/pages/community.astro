---
import Layout from '../layouts/Layout.astro';
import { communityStories } from '../data/community';
import { externalLinks } from '../data/links';
---

<Layout title="Community Involvement">
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-extrabold text-amber-900 mb-4 text-center">Community Involvement</h1>
    <p class="max-w-2xl mx-auto text-center text-stone-700 mb-12">
      From bake sales to tattoo fundraisers, our community shows up for Lucky Penny Kitties in ways
      big and small. Here are a few of our favorite partnerships and moments.
    </p>

    <div class="grid gap-6 sm:grid-cols-2">
      {communityStories.map((story) => (
        <div class="rounded-2xl border border-amber-100 p-6">
          <h2 class="font-bold text-amber-900 mb-2">{story.title}</h2>
          <p class="text-sm text-stone-700 leading-relaxed">{story.body}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <h2 class="text-xl font-bold text-amber-900 mb-3">Support LPK by Purchasing Our Merch</h2>
      <a
        href={externalLinks.merchStore}
        target="_blank"
        rel="noopener"
        class="inline-block px-6 py-3 rounded-full bg-amber-700 text-white font-semibold hover:bg-amber-800 transition-colors"
      >
        Shop Our Store
      </a>
    </div>
  </section>
</Layout>
