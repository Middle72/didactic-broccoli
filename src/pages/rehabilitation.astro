---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import CatCard from '../components/CatCard.astro';
import { getRehabCats, type Cat } from '../lib/airtable';

let cats: Cat[] = [];
let loadError = false;
try {
  cats = await getRehabCats();
} catch (err) {
  console.error(err);
  loadError = true;
}
---

<Layout title="Rehabilitation in Progress">
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-extrabold text-amber-900 mb-4 text-center">Rehabilitation in Progress</h1>
    <p class="max-w-2xl mx-auto text-center text-stone-700 mb-12">
      This page is dedicated to the cats in our care who need a little extra time, patience, and
      healing before they're ready for adoption.
    </p>

    {loadError && (
      <p class="text-center text-red-600 mb-8">
        We're having trouble loading rehab updates right now. Please check back soon.
      </p>
    )}

    {!loadError && cats.length === 0 && (
      <p class="text-center text-stone-500">
        No active rehabilitation cases right now — check back soon!
      </p>
    )}

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {cats.map((cat) => <CatCard cat={cat} />)}
    </div>
  </section>
</Layout>
