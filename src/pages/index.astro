---
import Layout from '../layouts/Layout.astro';
import { externalLinks, rescueStats } from '../data/links';
---

<Layout title="Home">
  <!-- Hero -->
  <section class="bg-amber-50 py-16 px-4 text-center">
    <h1 class="text-4xl sm:text-5xl font-extrabold text-amber-900 mb-4">Rescue. Love. Repeat.</h1>
    <p class="max-w-2xl mx-auto text-lg text-stone-700">
      Lucky Penny Kitties is a 501(c)(3) no-kill, foster-based cat rescue in Waverly, Iowa. We rescue,
      nurture, and advocate for cats and kittens in need — offering them a second chance through
      compassionate, in-home fostering, on our way to becoming a full-service humane society.
    </p>
  </section>

  <!-- Stats -->
  <section class="max-w-4xl mx-auto px-4 py-12 grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
    {rescueStats.map((s) => (
      <div class="rounded-2xl border border-amber-100 p-6">
        <p class="text-3xl font-extrabold text-amber-800">{s.rescued}</p>
        <p class="text-sm text-stone-500 mb-2">rescued in {s.year}</p>
        <p class="text-xl font-bold text-amber-700">{s.adopted}</p>
        <p class="text-sm text-stone-500">adopted</p>
      </div>
    ))}
  </section>

  <!-- Foster / Adopt CTA -->
  <section class="bg-stone-50 py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-amber-900 mb-4">Join Us — Help Them. Become a Foster!</h2>
      <p class="max-w-2xl mx-auto text-stone-700 mb-6">
        Every kitty we take in needs a safe, loving home while they wait for their forever family.
        Whether you can foster or you're ready to adopt, we'd love to hear from you.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={externalLinks.fosterForm}
          target="_blank"
          rel="noopener"
          class="px-6 py-3 rounded-full bg-amber-700 text-white font-semibold hover:bg-amber-800 transition-colors"
        >
          Apply to Foster
        </a>
        <a
          href={externalLinks.adoptForm}
          target="_blank"
          rel="noopener"
          class="px-6 py-3 rounded-full bg-amber-100 text-amber-900 font-semibold hover:bg-amber-200 transition-colors"
        >
          Apply to Adopt
        </a>
      </div>
    </div>
  </section>

  <!-- Donate -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-amber-900 mb-4">Help Us Achieve Our Goal by Donating Today</h2>
      <p class="max-w-2xl mx-auto text-stone-700 mb-8">
        Every dollar goes directly toward food, litter, vetting, and supplies for the cats in our care.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={externalLinks.zeffyDonate} target="_blank" rel="noopener" class="px-5 py-2.5 rounded-full border border-amber-700 text-amber-800 font-medium hover:bg-amber-50">Donate via Zeffy</a>
        <a href={externalLinks.paypalDonate} target="_blank" rel="noopener" class="px-5 py-2.5 rounded-full border border-amber-700 text-amber-800 font-medium hover:bg-amber-50">PayPal</a>
        <a href={externalLinks.venmo} target="_blank" rel="noopener" class="px-5 py-2.5 rounded-full border border-amber-700 text-amber-800 font-medium hover:bg-amber-50">Venmo</a>
        <a href={externalLinks.givingGrid} target="_blank" rel="noopener" class="px-5 py-2.5 rounded-full border border-amber-700 text-amber-800 font-medium hover:bg-amber-50">Giving Grid</a>
        <a href={externalLinks.amazonWishlist} target="_blank" rel="noopener" class="px-5 py-2.5 rounded-full border border-amber-700 text-amber-800 font-medium hover:bg-amber-50">Amazon Wishlist</a>
      </div>
    </div>
  </section>

  <!-- Merch -->
  <section class="bg-amber-50 py-16 px-4 text-center">
    <h2 class="text-2xl font-bold text-amber-900 mb-4">Support LPK by Purchasing Our Merch</h2>
    <a
      href={externalLinks.merchStore}
      target="_blank"
      rel="noopener"
      class="inline-block px-6 py-3 rounded-full bg-amber-700 text-white font-semibold hover:bg-amber-800 transition-colors"
    >
      Shop Our Store
    </a>
  </section>

  <!-- Surrender -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-amber-900 mb-4 text-center">How to Surrender a Kitty</h2>
      <p class="text-stone-700 mb-4">
        We accept surrenders as our foster space allows. A mandatory <strong>$25 surrender fee</strong>
        helps cover intake costs including food, litter, vetting, and supplies. Because space is
        limited, surrenders may be placed on a waitlist.
      </p>
      <p class="text-stone-700 mb-6">
        To start the process, fill out our Surrender Request Form, or email us directly if you have
        questions.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href={externalLinks.surrenderForm}
          target="_blank"
          rel="noopener"
          class="px-6 py-3 rounded-full bg-amber-700 text-white font-semibold hover:bg-amber-800 transition-colors"
        >
          Surrender Request Form
        </a>
        <a
          href="mailto:meow@luckypennykitties.org"
          class="px-6 py-3 rounded-full bg-amber-100 text-amber-900 font-semibold hover:bg-amber-200 transition-colors"
        >
          Email Us
        </a>
      </div>
    </div>
  </section>

  <!-- Email signup -->
  <section class="bg-stone-50 py-16 px-4 text-center">
    <h2 class="text-2xl font-bold text-amber-900 mb-4">Want to Help? Stay in the Loop</h2>
    <p class="max-w-xl mx-auto text-stone-700 mb-6">
      Sign up for occasional updates on adoptable kitties, events, and ways to help.
    </p>
    <a
      href={externalLinks.zeffyDonate}
      target="_blank"
      rel="noopener"
      class="inline-block px-6 py-3 rounded-full bg-amber-700 text-white font-semibold hover:bg-amber-800 transition-colors"
    >
      Subscribe via Zeffy
    </a>
  </section>
</Layout>
